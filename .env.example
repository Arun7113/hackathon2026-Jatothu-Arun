# Copy to .env and fill in your key
# Free key: https://aistudio.google.com/apikey

GEMINI_API_KEY=your_gemini_api_key_here

# Model strategy: fast model for simple tasks, smart for complex reasoning
GEMINI_FAST_MODEL=gemini-2.0-flash-lite    # classifier (saves quota)
GEMINI_SMART_MODEL=gemini-2.0-flash        # triage / act / reply

# Processing controls
MAX_TICKETS=20       # process all 20
BATCH_SIZE=3         # concurrent tickets per batch (keep low on free tier)
BATCH_DELAY=15       # seconds between batches (increase to 30-60 if hitting 429)
